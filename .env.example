# OverseasJob.in Main Environment Configuration
# Copy this file to .env and update values for your environment
# SECURITY: Never commit .env with real secrets to version control!

# ====================
# DATABASE
# ====================
MYSQL_ROOT_PASSWORD=change_me_in_production
MYSQL_DATABASE=overseasjob
MYSQL_USER=overseasjob
MYSQL_PASSWORD=change_me_in_production
DB_HOST=mysql
DB_PORT=3306

# ====================
# REDIS
# ====================
REDIS_PASSWORD=null
REDIS_HOST=redis
REDIS_PORT=6379

# ====================
# JWT AUTH
# ====================
JWT_SECRET=change_me_to_a_random_32_character_string_here_for_production
JWT_ALGORITHM=HS256

# ====================
# PAYMENT GATEWAYS
# ====================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Stripe (for future use)
STRIPE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ====================
# FILE STORAGE
# ====================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=overseasjob-resumes

# ====================
# AI SERVICE
# ====================
AI_SERVICE_URL=http://ai-service:5000

# ====================
# FRONTEND
# ====================
FRONTEND_URL=http://localhost
FRONTEND_PORT=3000
