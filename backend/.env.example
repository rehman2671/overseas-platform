# Laravel Backend Environment Configuration
# Copy to .env and configure for your environment
# SECURITY: Never commit .env with real secrets to version control!

# ====================
# APPLICATION
# ====================
APP_NAME=OverseasJob
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=base64:change_me_with_php_artisan_key_generate

# ====================
# LOGGING
# ====================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ====================
# DATABASE
# ====================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=overseasjob
DB_USERNAME=overseasjob
DB_PASSWORD=change_me_in_production

# ====================
# CACHE & QUEUE
# ====================
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ====================
# REDIS
# ====================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ====================
# MAIL
# ====================
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@overseasjob.test
MAIL_FROM_NAME="${APP_NAME}"

# ====================
# AWS S3 (File Storage)
# ====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=overseasjob-resumes
AWS_USE_PATH_STYLE_ENDPOINT=false

# ====================
# JWT AUTHENTICATION
# ====================
JWT_ALGORITHM=HS256
JWT_SECRET=change_me_to_a_random_32_character_string_here_for_production
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# ====================
# PAYMENT GATEWAYS
# ====================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Stripe (for future use)
STRIPE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ====================
# AI SERVICE
# ====================
AI_SERVICE_URL=http://ai-service:5000

# ====================
# RATE LIMITING
# ====================
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=100

STRIPE_KEY=your-stripe-key
STRIPE_SECRET=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
